# Database (used by backend + postgres container)
DB_NAME=portfolio_db
DB_USER=your_db_user
DB_PASSWORD=change-this-strong-password

# Backend — generate: ./scripts/generate-jwt-secret.sh
# After changing JWT_SECRET, all users must log in again.
JWT_SECRET=change-this-to-a-long-random-string
PORT=3001
NODE_ENV=production

# Public URL (for password reset emails)
APP_URL=https://portdiary.com

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://portdiary.com,https://www.portdiary.com

# Anthropic API (AI features)
ANTHROPIC_API_KEY=

# Stripe — auto Pro subscription (set STRIPE_ENABLED=true when keys are ready)
STRIPE_ENABLED=true
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_ID=

# Omise — PromptPay (phase 1) / cards (future)
OMISE_ENABLED=false
OMISE_PUBLIC_KEY=
OMISE_SECRET_KEY=
PRO_UPGRADE_DISABLED=false
PRO_UPGRADE_DISABLED_MESSAGE=ระบบชำระเงินปิดชั่วคราวระหว่างรออนุมัติ Omise กรุณาลองใหม่ภายหลัง

# Pro pricing label (Stripe Price should match this amount/currency)
PRO_MONTHLY_PRICE_THB=99

# Manual payment fallback (only when STRIPE_ENABLED=false)
PRO_PAYMENT_QR_URL=/promptpay-qr-99.png
PRO_PAYMENT_INSTRUCTIONS=

# Admin account bootstrap (gets role=admin on migration)
ADMIN_EMAIL=tanadon.sangkhatorn@gmail.com

# Email (SMTP) — required for OTP registration and password reset
# Examples: Resend SMTP, SendGrid SMTP, Mailgun
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="PortDiary <noreply@portdiary.com>"

# Trip Planner — place search (optional; falls back to OpenStreetMap)
GOOGLE_PLACES_API_KEY=
PLACE_SEARCH_USER_AGENT=PortDiary/1.0 (trip-planner; support@portdiary.com)
