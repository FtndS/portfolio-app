# Database (used by backend + postgres container)
DB_NAME=portfolio_db
DB_USER=your_db_user
DB_PASSWORD=change-this-strong-password

# Backend — generate: ./scripts/generate-jwt-secret.sh
# After changing JWT_SECRET, all users must log in again.
JWT_SECRET=change-this-to-a-long-random-string
PORT=3001
NODE_ENV=production

# Public URL (for password reset emails)
APP_URL=https://portdiary.com

# CORS — comma-separated allowed origins
CORS_ORIGINS=https://portdiary.com,https://www.portdiary.com

# Anthropic API (AI features)
ANTHROPIC_API_KEY=

# Stripe (future) — set true when payment gateway is wired
STRIPE_ENABLED=false

# Pro manual payment — shown on subscription page (bank / QR details)
PRO_MONTHLY_PRICE_THB=99
PRO_PAYMENT_QR_URL=/promptpay-qr-99.png
PRO_PAYMENT_INSTRUCTIONS=สแกน QR PromptPay ฿99/เดือน แล้วอัปโหลดสลิปในหน้าแผน Pro


# Admin account bootstrap (gets role=admin on migration)
ADMIN_EMAIL=tanadon.sangkhatorn@gmail.com

# Email (SMTP) — required for OTP registration and password reset
# Examples: Resend SMTP, SendGrid SMTP, Mailgun
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="PortDiary <noreply@portdiary.com>"
